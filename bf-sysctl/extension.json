{
  "name": "bf-sysctl",
  "commands": [
    {
      "command_name": "bf-sysctl",
      "help": "read/write kernel parameters",
      "entrypoint": "go",
      "files": [
        {
          "os": "linux",
          "arch": "amd64",
          "path": "sysctl.x64.obj"
        },
        {
          "os": "linux",
          "arch": "arm64",
          "path": "sysctl.aarch64.obj"
        }
      ],
      "arguments": [
        {
          "name": "key",
          "type": "string",
          "desc": "Sysctl key to read (omit to list all)",
          "optional": true
        },
        {
          "name": "filter",
          "type": "string",
          "desc": "Filter pattern when listing all",
          "optional": true
        }
      ]
    }
  ]
}
