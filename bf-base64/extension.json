{
  "name": "bf-base64",
  "commands": [
    {
      "command_name": "bf-base64",
      "help": "base64 encode/decode",
      "entrypoint": "go",
      "files": [
        {
          "os": "linux",
          "arch": "amd64",
          "path": "base64.x64.obj"
        },
        {
          "os": "linux",
          "arch": "arm64",
          "path": "base64.aarch64.obj"
        }
      ],
      "arguments": [
        {
          "name": "file",
          "type": "string",
          "desc": "File to encode/decode",
          "optional": true
        },
        {
          "name": "mode",
          "type": "string",
          "desc": "encode or decode",
          "optional": true,
          "default": "encode",
          "choices": [
            "encode",
            "decode"
          ]
        }
      ]
    }
  ]
}
