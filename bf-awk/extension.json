{
  "name": "bf-awk",
  "commands": [
    {
      "command_name": "bf-awk",
      "help": "minimal awk (print columns only)",
      "entrypoint": "go",
      "files": [
        {
          "os": "linux",
          "arch": "amd64",
          "path": "awk.x64.obj"
        },
        {
          "os": "linux",
          "arch": "arm64",
          "path": "awk.aarch64.obj"
        }
      ],
      "arguments": [
        {
          "name": "expression",
          "type": "string",
          "desc": "awk expression, e.g. '{print $1}'"
        },
        {
          "name": "file",
          "type": "string",
          "desc": "Input file",
          "optional": true
        },
        {
          "name": "delimiter",
          "type": "string",
          "desc": "Field separator (default: whitespace)",
          "optional": true
        }
      ]
    }
  ]
}
